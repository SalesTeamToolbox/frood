{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/context-loader.py",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/security-monitor.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python .claude/hooks/format-on-write.py",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session-handoff.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/test-validator.py",
            "timeout": 45
          },
          {
            "type": "command",
            "command": "python .claude/hooks/learning-engine.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
