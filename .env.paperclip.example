# -- Paperclip + Agent42 Stack Configuration ----------------------------------
# Copy to .env.paperclip and fill in values before running:
#   docker compose -f docker-compose.paperclip.yml up -d
#
# IMPORTANT: Internal Docker network URLs (REDIS_URL, QDRANT_URL, DATABASE_URL,
# AGENT42_SIDECAR_URL, PAPERCLIP_API_URL) are set in docker-compose.paperclip.yml.
# Do NOT override them here -- doing so will break container networking.

# -- PostgreSQL ----------------------------------------------------------------
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=changeme-use-a-strong-password
POSTGRES_DB=paperclip
POSTGRES_PORT=5432

# -- Redis ---------------------------------------------------------------------
REDIS_PORT=6379

# -- Qdrant --------------------------------------------------------------------
QDRANT_PORT=6333

# -- Agent42 Sidecar -----------------------------------------------------------
# Port exposed on host for agent42-sidecar (container always listens on 8001)
SIDECAR_PORT=8001

# LLM Provider API Keys (at least one required for agent execution)
# See .env.example for full list of supported providers
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dashboard auth (used by sidecar for JWT token validation)
JWT_SECRET=generate-with-python-c-import-secrets-print-secrets-token_hex-32
DASHBOARD_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sandbox (always enabled in production)
SANDBOX_ENABLED=true

# -- Paperclip -----------------------------------------------------------------
PAPERCLIP_PORT=3000
# Paperclip-specific configuration (consult Paperclip docs)
# PAPERCLIP_SECRET_KEY=
# PAPERCLIP_COMPANY_ID=
