{
  "name": "@frood/paperclip-plugin",
  "version": "1.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker-launcher.cjs",
    "ui": "./dist/ui/"
  },
  "scripts": {
